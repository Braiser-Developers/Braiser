{
  "name": "braiser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:extension && npm run build:mcp",
    "build:extension": "tsc -p extension/tsconfig.json",
    "build:mcp": "tsc -p mcp/tsconfig.json",
    "check": "npm run build",
    "setup:markdown": "node scripts/setup-markdown.mjs",
    "cli": "node mcp/dist/cli.js",
    "download:dom": "node mcp/dist/cli.js dom",
    "download:observe": "node mcp/dist/cli.js observe",
    "download:markdown": "node mcp/dist/cli.js markdown",
    "download:md": "node mcp/dist/cli.js md",
    "download:preprocessed-html": "node mcp/dist/cli.js preprocessed-html",
    "download:debug-html": "node mcp/dist/cli.js debug-html",
    "download:both": "node mcp/dist/cli.js both",
    "mcp": "node mcp/dist/server.js",
    "daemon": "node mcp/dist/daemon.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.306",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.2"
  }
}
